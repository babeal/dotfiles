{{- if and (eq .chezmoi.os "linux") .install_packages -}}
#!/usr/bin/env bash

{{ template "shared_script_utils.bash" . }}

header "Install Linuxbrew packages"

set +e
brew update
set -e

set +e
brew bundle --no-upgrade --file=/dev/stdin <<EOF

{{/* Taps */}}
{{ range .packages.linuxbrew.common.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ if .dev_computer -}}
{{ range .packages.linuxbrew.dev.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ end -}}
{{ if .personal_computer -}}
{{ range .packages.linuxbrew.personal.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ end -}}

{{/* Formulae */}}
{{ range .packages.linuxbrew.common.formulae -}}
brew {{ .name | quote }}{{ if index . "extra" }}, {{ index . "extra" }}{{ end }}
{{ end -}}
{{ if .dev_computer -}}
{{ range .packages.linuxbrew.dev.formulae -}}
brew {{ .name | quote }}{{ if index . "extra" }}, {{ index . "extra" }}{{ end }}
{{ end -}}
{{ end -}}
{{ if .personal_computer -}}
{{ range .packages.linuxbrew.personal.formulae -}}
brew {{ .name | quote }}{{ if index . "extra" }}, {{ index . "extra" }}{{ end }}
{{ end -}}
{{ end -}}
EOF
_bundle_exit=$?
set -e

if [[ $_bundle_exit -ne 0 ]]; then
    warning "Some Linuxbrew packages failed to install — review output above"
    mkdir -p "${HOME}/.local/state/dotfiles"
    echo "$(date -u +"%Y-%m-%dT%H:%M:%SZ") linuxbrew-bundle exit=${_bundle_exit}" \
        >> "${HOME}/.local/state/dotfiles/install-failures.log"
fi

success "Linuxbrew packages complete"

_safeExit_

{{- end }}
