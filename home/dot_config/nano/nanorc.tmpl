# enables the minibar feature
set minibar

# disable inverse text for the minibar
set titlecolor normal,normal

# Display over multiple screen rows line that exceed the screen's width.
set softwrap
set atblanks

# Set tab size
set tabsize 4

# Replace Tabs With Spaces
set tabstospaces

# Automatically indent a newly created line to the same number of tabs and/or
# spaces as the previous line.
set autoindent
